{
  "mcp": {
    "name": "filesystem",
    "version": "2.0.0",
    "authentication": "bearer",
    "auth": {
      "type": "bearer",
      "header": "Authorization"
    },
    "tools": [
      "read_file",
      "write_file",
      "delete_file",
      "delete_directory",
      "run_command",
      "find_files",
      "extract_archive",
      "summarize_file",
      "analyse_secret",
      "search_links",
      "render_dashboard",
      "echo_tag",
      "verify_jwt_none",
      "fetch_remote",
      "load_cached",
      "record_login",
      "bloated_query"
    ],
    "capabilities": {
      "tools": {"listChanged": true}
    }
  },
  "mcpServers": {
    "files": {
      "command": "python",
      "args": ["server.py"],
      "roots": ["/srv/mcp-files"]
    }
  }
}
